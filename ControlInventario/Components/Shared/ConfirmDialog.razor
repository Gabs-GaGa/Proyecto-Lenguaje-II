@if (_isVisible)
{
    <!-- Modal Backdrop -->
    <div class="modal-backdrop fade show" style="background-color: rgba(0, 0, 0, 0.5); z-index: 1040;"></div>

    <!-- Modal Dialog -->
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1050; overflow-y: auto;" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white py-3">
                    <h5 class="modal-title fw-bold m-0">
                        <i class="bi bi-question-circle-fill me-2"></i>@_title
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Cancel" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="fs-5 mb-0 text-dark">@_message</p>
                </div>
                <div class="modal-footer bg-light py-2">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="Cancel">No</button>
                    <button type="button" class="btn btn-primary px-4 fw-semibold" @onclick="Confirm">Sí</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isVisible;
    private string _title = string.Empty;
    private string _message = string.Empty;
    private TaskCompletionSource<bool>? _tcs;

    public Task<bool> ShowAsync(string title, string message)
    {
        _title = title;
        _message = message;
        _isVisible = true;
        _tcs = new TaskCompletionSource<bool>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void Confirm()
    {
        _isVisible = false;
        _tcs?.SetResult(true);
    }

    private void Cancel()
    {
        _isVisible = false;
        _tcs?.SetResult(false);
    }
}
