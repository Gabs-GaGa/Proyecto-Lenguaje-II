@if (IsOpen)
{
    <!-- Backdrop del Modal -->
    <div style="position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.5); z-index: 1050;" @onclick="CloseAsync"></div>

    <!-- Cuadro Central del Modal -->
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 24px; border-radius: 12px; max-width: 500px; width: 90%; z-index: 1060; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);" role="dialog" aria-modal="true">
        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
            <h5 class="m-0 fw-bold text-primary">Formulario de Categoría</h5>
            <button type="button" class="btn-close" @onclick="CloseAsync" aria-label="Close"></button>
        </div>
        
        <div>
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] 
    public bool IsOpen { get; set; }

    [Parameter] 
    public RenderFragment? ChildContent { get; set; }

    [Parameter] 
    public EventCallback OnClose { get; set; }

    private async Task CloseAsync()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }
}
