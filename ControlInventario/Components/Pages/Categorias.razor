@page "/categorias"

<PageTitle>Categorías - SGI Inventario</PageTitle>

<div class="row">
    <div class="col-12">
        <!-- Tarjeta de Gestión de Categorías (Diseño Premium AdminLTE 4) -->
        <div class="card card-primary card-outline mb-4 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between py-3 bg-white">
                <h5 class="card-title m-0 fw-bold text-primary">
                    <i class="bi bi-tags me-2"></i>Gestión de Categorías
                </h5>
            </div>
            <div class="card-body p-0">
                <!-- Tabla Responsiva de Categorías -->
                <table class="table table-bordered table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px" class="text-center">ID</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th style="width: 150px" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (CategoriasList == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-secondary">
                                    <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                    Cargando categorías...
                                </td>
                            </tr>
                        }
                        else if (!CategoriasList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    <i class="bi bi-info-circle me-1"></i> No se encontraron categorías registradas.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var cat in CategoriasList)
                            {
                                <tr>
                                    <td class="text-center fw-semibold">@cat.Id</td>
                                    <td class="fw-medium text-dark">@cat.Nombre</td>
                                    <td class="text-secondary">@cat.Descripcion</td>
                                    <td class="text-center">
                                        <!-- Botones de Acción directos -->
                                        <button class="btn btn-sm btn-outline-warning me-1" @onclick='() => Console.WriteLine("Editar Categoría: " + cat.Id)' title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick='() => Console.WriteLine("Eliminar Categoría: " + cat.Id)' title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<CategoriaDto> CategoriasList = new()
    {
        new CategoriaDto { Id = 1, Nombre = "Electrónicos", Descripcion = "Productos tecnológicos y de computación" },
        new CategoriaDto { Id = 2, Nombre = "Oficina", Descripcion = "Artículos de papelería, escritorios y organización" },
        new CategoriaDto { Id = 3, Nombre = "Hogar", Descripcion = "Muebles, decoración y productos para el hogar" }
    };

    public class CategoriaDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
    }
}
