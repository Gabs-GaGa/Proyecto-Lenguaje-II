@page "/"
@rendermode InteractiveServer
@using ControlInventario.Models.Enums
@inject IProductoService ProductoService
@inject ICategoriaService CategoriaService
@inject IProveedorService ProveedorService
@inject IMovimientoInventarioService MovimientoService
@inject INotificationService Notification

<div>
    <PageTitle>Dashboard - SGI Inventario</PageTitle>

    <!-- Mensaje de Bienvenida -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-5 bg-white rounded-3 shadow-sm border-start border-primary border-5">
                <h1 class="display-5 fw-bold text-dark mb-2">Bienvenido al Sistema de Inventario</h1>
                <p class="col-md-8 fs-5 text-secondary">
                    Gestión integral de categorías, proveedores, productos y movimientos de inventario en tiempo real.
                </p>
            </div>
        </div>
    </div>

    <!-- Grid de KPIs (Widgets de AdminLTE 4) -->
    <div class="row mb-4">
        <!-- Total Productos -->
        <div class="col-lg-3 col-6 mb-3">
            <div class="small-box text-bg-primary shadow-sm h-100 position-relative rounded-3 p-3">
                <div class="inner">
                    <h3 class="fw-bold mb-1">@TotalProductos</h3>
                    <p class="mb-3 text-white-50">Total Productos</p>
                </div>
                <div class="icon position-absolute top-50 end-0 translate-middle-y me-3 opacity-25">
                    <i class="bi bi-box-seam fs-1 text-white"></i>
                </div>
                <a href="/productos" class="small-box-footer d-block text-white text-decoration-none mt-2 fs-7 text-center">
                    Ver Listado <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                </a>
            </div>
        </div>

        <!-- Total Categorías -->
        <div class="col-lg-3 col-6 mb-3">
            <div class="small-box text-bg-success shadow-sm h-100 position-relative rounded-3 p-3">
                <div class="inner">
                    <h3 class="fw-bold mb-1">@TotalCategorias</h3>
                    <p class="mb-3 text-white-50">Total Categorías</p>
                </div>
                <div class="icon position-absolute top-50 end-0 translate-middle-y me-3 opacity-25">
                    <i class="bi bi-tags fs-1 text-white"></i>
                </div>
                <a href="/categorias" class="small-box-footer d-block text-white text-decoration-none mt-2 fs-7 text-center">
                    Ver Listado <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                </a>
            </div>
        </div>

        <!-- Stock Bajo -->
        <div class="col-lg-3 col-6 mb-3">
            <div class="small-box text-bg-danger shadow-sm h-100 position-relative rounded-3 p-3">
                <div class="inner">
                    <h3 class="fw-bold mb-1">@StockBajoCount</h3>
                    <p class="mb-3 text-white-50">Stock Bajo</p>
                </div>
                <div class="icon position-absolute top-50 end-0 translate-middle-y me-3 opacity-25">
                    <i class="bi bi-exclamation-triangle fs-1 text-white"></i>
                </div>
                <a href="/productos" class="small-box-footer d-block text-white text-decoration-none mt-2 fs-7 text-center">
                    Ver Alertas <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                </a>
            </div>
        </div>

        <!-- Total Proveedores -->
        <div class="col-lg-3 col-6 mb-3">
            <div class="small-box text-bg-warning shadow-sm h-100 position-relative rounded-3 p-3">
                <div class="inner text-dark">
                    <h3 class="fw-bold mb-1 text-dark">@TotalProveedores</h3>
                    <p class="mb-3 text-dark text-opacity-75">Total Proveedores</p>
                </div>
                <div class="icon position-absolute top-50 end-0 translate-middle-y me-3 opacity-25">
                    <i class="bi bi-people fs-1 text-dark"></i>
                </div>
                <a href="/proveedores" class="small-box-footer d-block text-dark text-decoration-none mt-2 fs-7 text-center">
                    Ver Listado <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Secciones Dinámicas: Stock Bajo & Últimos Movimientos -->
    <div class="row">
        <!-- Stock Bajo -->
        <div class="col-lg-6 col-12 mb-4">
            <div class="card card-danger card-outline shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title m-0 fw-bold text-danger">
                        <i class="bi bi-exclamation-octagon me-2"></i>Productos con Stock Bajo
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Nombre</th>
                                    <th class="text-center" style="width: 110px">Stock Actual</th>
                                    <th class="text-center" style="width: 110px">Stock Mínimo</th>
                                    <th>Categoría</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ProductosStockBajo == null)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-secondary">
                                            <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                            Cargando productos con stock bajo...
                                        </td>
                                    </tr>
                                }
                                else if (!ProductosStockBajo.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            <i class="bi bi-check-circle text-success me-1"></i> No hay productos con stock bajo.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var prod in ProductosStockBajo)
                                    {
                                        <tr>
                                            <td class="fw-medium text-dark">@prod.Nombre</td>
                                            <td class="text-center">
                                                <span class="badge bg-danger px-2.5 py-1.5 fs-7">@prod.StockActual</span>
                                            </td>
                                            <td class="text-center text-secondary">@prod.StockMinimo</td>
                                            <td class="text-secondary">@(prod.Categoria?.Nombre ?? "Sin categoría")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimos Movimientos -->
        <div class="col-lg-6 col-12 mb-4">
            <div class="card card-primary card-outline shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title m-0 fw-bold text-primary">
                        <i class="bi bi-arrow-left-right me-2"></i>Últimos Movimientos
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center" style="width: 100px">Tipo</th>
                                    <th class="text-center" style="width: 90px">Cantidad</th>
                                    <th>Fecha</th>
                                    <th>Motivo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (UltimosMovimientos == null)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-secondary">
                                            <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                            Cargando últimos movimientos...
                                        </td>
                                    </tr>
                                }
                                else if (!UltimosMovimientos.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">
                                            <i class="bi bi-info-circle me-1"></i> No hay movimientos registrados.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var mov in UltimosMovimientos)
                                    {
                                        <tr>
                                            <td class="fw-medium text-dark text-truncate" style="max-width: 150px;">@(mov.Producto?.Nombre ?? "Producto no encontrado")</td>
                                            <td class="text-center">
                                                <span class="badge @GetTipoBadgeClass(mov.Tipo) px-2.5 py-1.5 fs-7">@mov.Tipo</span>
                                            </td>
                                            <td class="text-center fw-semibold text-dark">@mov.Cantidad</td>
                                            <td class="text-secondary">@mov.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-secondary text-truncate" style="max-width: 130px;">@mov.Motivo</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fila con accesos directos -->
    <div class="row">
        <div class="col-md-12">
            <div class="card card-primary card-outline shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title m-0 fw-bold text-dark"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Acceso Directo Administrativo</h5>
                </div>
                <div class="card-body">
                    <p class="text-secondary mb-4">Utiliza los siguientes accesos directos para iniciar tareas operativas rápidas en tu inventario:</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/productos" class="btn btn-primary d-flex align-items-center">
                            <i class="bi bi-plus-circle me-2"></i> Nuevo Producto
                        </a>
                        <a href="/categorias" class="btn btn-success d-flex align-items-center">
                            <i class="bi bi-folder-plus me-2"></i> Nueva Categoría
                        </a>
                        <a href="/movimientos" class="btn btn-warning d-flex align-items-center text-dark">
                            <i class="bi bi-arrow-left-right me-2"></i> Registrar Movimiento
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <LoadingSpinner IsLoading="IsLoading" />
</div>

@code {
    private int TotalProductos { get; set; }
    private int TotalCategorias { get; set; }
    private int TotalProveedores { get; set; }
    private int StockBajoCount { get; set; }
    private List<Producto> ProductosStockBajo { get; set; } = new();
    private List<MovimientoInventario> UltimosMovimientos { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        await LoadDashboardData();
        IsLoading = false;
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var productos = await ProductoService.GetAllAsync();
            TotalProductos = productos.Count;

            var categorias = await CategoriaService.GetAllAsync();
            TotalCategorias = categorias.Count;

            var proveedores = await ProveedorService.GetAllAsync();
            TotalProveedores = proveedores.Count;

            ProductosStockBajo = productos.Where(p => p.StockActual <= p.StockMinimo).ToList();
            StockBajoCount = ProductosStockBajo.Count;

            var movimientos = await MovimientoService.GetAllAsync();
            UltimosMovimientos = movimientos.OrderByDescending(m => m.Fecha).Take(5).ToList();
        }
        catch (Exception ex)
        {
            Notification.ShowError("Error al cargar los datos del panel de control.");
            Console.WriteLine("Error al conectar con la BD en Dashboard: " + ex.Message);
        }
    }

    private string GetTipoBadgeClass(TipoMovimiento tipo)
    {
        return tipo switch
        {
            TipoMovimiento.Entrada => "bg-success",
            TipoMovimiento.Salida => "bg-danger",
            TipoMovimiento.Ajuste => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}
