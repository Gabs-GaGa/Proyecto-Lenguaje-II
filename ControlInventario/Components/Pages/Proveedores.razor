@page "/proveedores"

<PageTitle>Proveedores - SGI Inventario</PageTitle>

<div class="row">
    <div class="col-12">
        <!-- Tarjeta de Gestión de Proveedores (Diseño Premium AdminLTE 4) -->
        <div class="card card-primary card-outline mb-4 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between py-3 bg-white">
                <h5 class="card-title m-0 fw-bold text-primary">
                    <i class="bi bi-truck me-2"></i>Gestión de Proveedores
                </h5>
            </div>
            <div class="card-body p-0">
                <!-- Tabla Responsiva de Proveedores -->
                <table class="table table-bordered table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px" class="text-center">ID</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th style="width: 150px" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ProveedoresList == null)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-secondary">
                                    <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                    Cargando proveedores...
                                </td>
                            </tr>
                        }
                        else if (!ProveedoresList.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="bi bi-info-circle me-1"></i> No se encontraron proveedores registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var prov in ProveedoresList)
                            {
                                <tr>
                                    <td class="text-center fw-semibold">@prov.Id</td>
                                    <td class="fw-medium text-dark">@prov.Nombre</td>
                                    <td class="text-secondary">@prov.Telefono</td>
                                    <td class="text-secondary">@prov.Email</td>
                                    <td class="text-center">
                                        <!-- Botones de Acción -->
                                        <button class="btn btn-sm btn-outline-warning me-1" @onclick='() => Console.WriteLine("Editar Proveedor: " + prov.Id)' title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick='() => Console.WriteLine("Eliminar Proveedor: " + prov.Id)' title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ProveedorDto> ProveedoresList = new()
    {
        new ProveedorDto { Id = 1, Nombre = "Proveedor de Tecnología S.A. (Proveedor A)", Telefono = "+1 (555) 019-2834", Email = "ventas@proveedora.com" },
        new ProveedorDto { Id = 2, Nombre = "Logística y Suministros Express (Proveedor B)", Telefono = "+1 (555) 014-9988", Email = "contacto@proveedorb.com" },
        new ProveedorDto { Id = 3, Nombre = "Importaciones Globales Limitada (Proveedor C)", Telefono = "+1 (555) 017-4567", Email = "soporte@proveedorc.com" }
    };

    public class ProveedorDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Telefono { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }
}
