# ──────────────────────────────────────────────
#  .gitignore para Proyecto .NET (Blazor + EF)
# ──────────────────────────────────────────────

# ── Directorios de compilación ──
bin/
obj/
[Dd]ebug/
[Rr]elease/
packages/

# ── Archivos de usuario del IDE ──
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
*.code-workspace

# ── NuGet ──
*.nupkg
*.nuget.props
*.nuget.targets

# ── Resultados de pruebas ──
[Tt]est[Rr]esult*
[Bb]uild[Ss]cript/
[Tt]est[Cc]overage/
*.trx
*.coverage

# ── Logs ──
*.log
logs/

# ── Entorno y secretos ──
.env
*.env.local

# ── Cache de EF / Migraciones temporales ──
__azurite_db*__.json
__blobstorage*__
__queuestorage*__

# ── Sistema operativo ──
Thumbs.db
.DS_Store

# ── Otros archivos generados ──
*.pyc
*.pyo
__pycache__/
